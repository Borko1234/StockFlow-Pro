@model StockFlowPro.ViewModels.ScannerViewModel

@{
    ViewData["Title"] = "Scanner Station";
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="toast-container position-fixed top-0 end-0 p-3">
        <div id="scanSuccessToast" class="toast text-bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body">
                    Scan successful!
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0"><i class="bi bi-upc-scan"></i> Scanner Station</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Scan" method="post" class="mb-4">
                        <div class="input-group input-group-lg">
                            <span class="input-group-text" id="scan-icon">Order ID</span>
                            @if (Model.CurrentOrder == null)
                            {
                                <input type="number" id="orderIdInput" name="orderId" class="form-control" placeholder="Enter Order ID..." aria-label="Order ID" aria-describedby="scan-icon" required>
                            }
                            else
                            {
                                <input type="number" id="orderIdInput" name="orderId" class="form-control" placeholder="Enter Order ID..." aria-label="Order ID" aria-describedby="scan-icon" required>
                            }
                            <button class="btn btn-success" type="submit">Scan Order</button>
                        </div>
                    </form>

                    @if (Model.CurrentOrder != null)
                    {
                        <div class="card mt-3 border-success">
                            <div class="card-header bg-success text-white">
                                <strong>Order Details: #@Model.CurrentOrder.Id</strong>
                            </div>
                            <div class="card-body">
                                <p><strong>Status:</strong> @Model.CurrentOrder.OrderStatus</p>
                                <p><strong>Total Items:</strong> @Model.TotalItems</p>
                                <p><strong>Remaining Items:</strong> @Model.RemainingItems</p>
                                <form asp-action="ScanProduct" method="post" class="mb-3" id="scanProductForm">
                                    <input type="hidden" name="orderId" value="@Model.CurrentOrder.Id" />
                                    <input type="hidden" name="remainingProductIds" value="@Model.RemainingProductIdsCsv" />
                                    <div class="input-group input-group-lg">
                                        <span class="input-group-text" id="product-scan-icon">Product ID</span>
                                        <input type="number" id="productIdInput" name="productId" class="form-control" placeholder="Enter Product ID..." aria-label="Product ID" aria-describedby="product-scan-icon" required>
                                        <button class="btn btn-primary" type="submit">Scan Product</button>
                                    </div>
                                    <div class="mt-3">
                                        <div class="d-flex flex-wrap gap-2">
                                            <button type="button" class="btn btn-outline-secondary" id="showCameraOptionsButton">Choose Camera</button>
                                            <button type="button" class="btn btn-outline-primary" id="startCameraScanButton" disabled>Start Camera Scan</button>
                                            <button type="button" class="btn btn-outline-secondary" id="stopCameraScanButton" disabled>Stop Camera</button>
                                        </div>
                                        <div class="form-text mt-2">
                                            Choose a camera first, then click `Start Camera Scan` and allow camera access when your browser asks.
                                        </div>
                                        <div class="mt-3 d-none" id="cameraScannerPanel">
                                            <label for="cameraSourceSelect" class="form-label">Camera Source</label>
                                            <select id="cameraSourceSelect" class="form-select mb-3"></select>
                                            <video id="cameraPreview" class="w-100 rounded border bg-dark d-none" style="max-height: 320px;" playsinline muted></video>
                                            <div id="cameraScannerStatus" class="form-text mt-2"></div>
                                        </div>
                                    </div>
                                    <div class="mt-3">
                                        <label class="form-label">Prepared By (Packer)</label>
                                        <select name="selectedPackerId" id="packerSelect" class="form-select">
                                            <option value="">Select Packer</option>
                                            @foreach (var packer in Model.Packers)
                                            {
                                                if (Model.SelectedPackerId == packer.Id)
                                                {
                                                    <option value="@packer.Id" selected="selected">@packer.FullName</option>
                                                }
                                                else
                                                {
                                                    <option value="@packer.Id">@packer.FullName</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                </form>
                                <hr />
                                <h5>Items:</h5>
                                <ul class="list-group">
                                    @foreach (var item in Model.Items)
                                    {
                                        <li class="list-group-item d-flex justify-content-between align-items-center @(item.IsScanned ? "list-group-item-success" : "")">
                                            <div>
                                                <div>@item.ProductName</div>
                                                <small class="text-muted">ID: @item.ProductId | Brand: @item.Brand | Price: @item.Price.ToString("C")</small>
                                            </div>
                                            @if (item.IsScanned)
                                            {
                                                <span class="badge bg-success rounded-pill">Scanned</span>
                                            }
                                        </li>
                                    }
                                </ul>
                                <form asp-action="MarkOrderScanned" method="post" class="mt-3">
                                    <input type="hidden" name="orderId" value="@Model.CurrentOrder.Id" />
                                    <input type="hidden" name="remainingProductIds" value="@Model.RemainingProductIdsCsv" />
                                    <input type="hidden" id="selectedPackerIdInput" name="selectedPackerId" value="@Model.SelectedPackerId" />
                                    @if (Model.AllItemsScanned && Model.SelectedPackerId.HasValue)
                                    {
                                        <button class="btn btn-success" id="markOrderScannedButton" type="submit" data-remaining="@Model.RemainingItems">Mark Order as Scanned</button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-success" id="markOrderScannedButton" type="submit" data-remaining="@Model.RemainingItems" disabled>Mark Order as Scanned</button>
                                    }
                                </form>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger mt-3" role="alert">
                            <i class="bi bi-exclamation-triangle-fill"></i> @Model.ErrorMessage
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                    {
                        <div class="alert alert-success mt-3" role="alert">
                            <i class="bi bi-check-circle-fill"></i> @Model.SuccessMessage
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script type="module">
        import { BrowserCodeReader, BrowserMultiFormatReader } from "https://esm.sh/%40zxing/browser";

        const packerSelect = document.getElementById("packerSelect");
        const markButton = document.getElementById("markOrderScannedButton");
        const packerHidden = document.getElementById("selectedPackerIdInput");
        const scanProductForm = document.getElementById("scanProductForm");
        const orderIdInput = document.getElementById("orderIdInput");
        const productIdInput = document.getElementById("productIdInput");
        const showCameraOptionsButton = document.getElementById("showCameraOptionsButton");
        const startCameraScanButton = document.getElementById("startCameraScanButton");
        const stopCameraScanButton = document.getElementById("stopCameraScanButton");
        const cameraScannerPanel = document.getElementById("cameraScannerPanel");
        const cameraSourceSelect = document.getElementById("cameraSourceSelect");
        const cameraPreview = document.getElementById("cameraPreview");
        const cameraScannerStatus = document.getElementById("cameraScannerStatus");
        const scanSuccessToast = document.getElementById("scanSuccessToast");
        let cameraCodeReader = null;
        let cameraScannerControls = null;
        let selectedCameraId = localStorage.getItem("scanner.selectedCameraId");
        const cameraPanelPreferenceKey = "scanner.cameraPanelVisible";
        const shouldShowSuccessPopup = @Json.Serialize(Model.CurrentOrder != null && !string.IsNullOrEmpty(Model.SuccessMessage));
        const shouldRestoreCameraPanel = localStorage.getItem(cameraPanelPreferenceKey) === "true"
            && @Json.Serialize(Model.CurrentOrder != null && !Model.AllItemsScanned);

        const setCameraStatus = (message) => {
            if (cameraScannerStatus)
            {
                cameraScannerStatus.textContent = message;
            }
        };

        const saveCameraPreferences = (cameraPanelVisible) => {
            if (selectedCameraId)
            {
                localStorage.setItem("scanner.selectedCameraId", selectedCameraId);
            }
            else
            {
                localStorage.removeItem("scanner.selectedCameraId");
            }

            localStorage.setItem(cameraPanelPreferenceKey, cameraPanelVisible ? "true" : "false");
        };

        const setCameraPanelVisibility = (isVisible) => {
            if (!cameraScannerPanel) return;

            cameraScannerPanel.classList.toggle("d-none", !isVisible);
            if (!isVisible && cameraPreview)
            {
                cameraPreview.classList.add("d-none");
            }
            saveCameraPreferences(isVisible);
        };

        const updateStartButtonState = () => {
            if (!startCameraScanButton) return;
            startCameraScanButton.disabled = !selectedCameraId;
        };

        const updateMarkButtonState = () => {
            if (!markButton) return;
            const remaining = parseInt(markButton.getAttribute("data-remaining") || "0", 10);
            const hasPacker = packerSelect && packerSelect.value;
            if (packerHidden && packerSelect)
            {
                packerHidden.value = packerSelect.value;
            }
            markButton.disabled = remaining > 0 || !hasPacker;
        };

        if (packerSelect && markButton)
        {
            packerSelect.addEventListener("change", updateMarkButtonState);
            updateMarkButtonState();
        }

        if (productIdInput && scanProductForm)
        {
            productIdInput.focus({ preventScroll: true });
        }
        else if (orderIdInput)
        {
            orderIdInput.focus({ preventScroll: true });
        }

        const stopCameraScanner = (clearStatus = false, clearPreferences = false) => {
            if (cameraScannerControls)
            {
                cameraScannerControls.stop();
                cameraScannerControls = null;
            }

            if (cameraPreview && cameraPreview.srcObject)
            {
                cameraPreview.srcObject.getTracks().forEach(track => track.stop());
                cameraPreview.srcObject = null;
            }

            if (cameraPreview)
            {
                cameraPreview.classList.add("d-none");
            }
            if (startCameraScanButton)
            {
                startCameraScanButton.disabled = false;
            }
            if (stopCameraScanButton)
            {
                stopCameraScanButton.disabled = true;
            }
            if (clearStatus)
            {
                setCameraStatus("");
            }
            if (clearPreferences)
            {
                setCameraPanelVisibility(false);
            }
        };

        const stopMediaStream = (stream) => {
            if (stream)
            {
                stream.getTracks().forEach(track => track.stop());
            }
        };

        const ensureCameraPermission = async () => {
            setCameraStatus("Allow camera access in the browser prompt to continue.");
            try
            {
                const permissionStream = await navigator.mediaDevices.getUserMedia({
                    video: { facingMode: { ideal: "environment" } },
                    audio: false
                });
                stopMediaStream(permissionStream);
                return true;
            }
            catch (error)
            {
                setCameraStatus(`Camera permission failed: ${error?.message || error}`);
                return false;
            }
        };

        const getPreferredCameraId = (devices) => {
            if (!devices.length)
            {
                return null;
            }

            const preferredDevice = devices.find(device => {
                const label = (device.label || "").toLowerCase();
                return label.includes("back") || label.includes("rear") || label.includes("environment");
            });

            return (preferredDevice || devices[0]).deviceId;
        };

        const loadCameraDevices = async () => {
            if (!cameraSourceSelect) return;

            const devices = await BrowserCodeReader.listVideoInputDevices();
            cameraSourceSelect.innerHTML = "";

            if (!devices.length)
            {
                selectedCameraId = null;
                return;
            }

            devices.forEach(device => {
                const option = document.createElement("option");
                option.value = device.deviceId;
                option.textContent = device.label || `Camera ${cameraSourceSelect.options.length + 1}`;
                cameraSourceSelect.appendChild(option);
            });

            selectedCameraId = selectedCameraId && devices.some(device => device.deviceId === selectedCameraId)
                ? selectedCameraId
                : getPreferredCameraId(devices);
            cameraSourceSelect.value = selectedCameraId;
            saveCameraPreferences(localStorage.getItem(cameraPanelPreferenceKey) === "true");
            updateStartButtonState();
        };

        const buildCameraConstraints = () => {
            const constraints = [];

            if (selectedCameraId)
            {
                constraints.push({ video: { deviceId: { exact: selectedCameraId } }, audio: false });
            }

            constraints.push({ video: { facingMode: { ideal: "environment" } }, audio: false });
            constraints.push({ video: true, audio: false });

            return constraints;
        };

        const shouldTryNextConstraint = (error) => {
            const message = `${error?.name || ""} ${error?.message || error || ""}`.toLowerCase();
            return message.includes("could not start video source")
                || message.includes("notreadable")
                || message.includes("overconstrained")
                || message.includes("notfound")
                || message.includes("devicesnotfound");
        };

        const startDecoding = async () => {
            const constraintsOptions = buildCameraConstraints();
            let lastError = null;

            for (const constraints of constraintsOptions)
            {
                try
                {
                    cameraScannerControls = await cameraCodeReader.decodeFromConstraints(
                        constraints,
                        cameraPreview,
                        (result, error) => {
                            if (result)
                            {
                                const scannedValue = result.getText().trim();
                                productIdInput.value = scannedValue;
                                setCameraStatus(`Scanned value: ${scannedValue}`);
                                stopCameraScanner();
                                scanProductForm.requestSubmit();
                                return;
                            }

                            if (error && error.name !== "NotFoundException")
                            {
                                setCameraStatus(`Scanner error: ${error.message || error}`);
                            }
                        });

                    return;
                }
                catch (error)
                {
                    lastError = error;
                    if (!shouldTryNextConstraint(error))
                    {
                        throw error;
                    }
                }
            }

            throw lastError || new Error("No camera configuration could be started.");
        };

        const startCameraScanner = async () => {
            if (!productIdInput || !scanProductForm || !cameraPreview || !cameraScannerPanel)
            {
                return;
            }

            if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia)
            {
                setCameraStatus("Camera access is not supported in this browser.");
                return;
            }

            if (!selectedCameraId)
            {
                setCameraStatus("Choose a camera before starting the scanner.");
                return;
            }

            try
            {
                const permissionGranted = await ensureCameraPermission();
                if (!permissionGranted)
                {
                    return;
                }

                if (!cameraCodeReader)
                {
                    cameraCodeReader = new BrowserMultiFormatReader();
                }

                stopCameraScanner();
                setCameraPanelVisibility(true);
                if (cameraPreview)
                {
                    cameraPreview.classList.remove("d-none");
                }
                setCameraStatus("Starting camera. Point it at a product code.");
                if (startCameraScanButton)
                {
                    startCameraScanButton.disabled = true;
                }
                if (stopCameraScanButton)
                {
                    stopCameraScanButton.disabled = false;
                }

                await startDecoding();
            }
            catch (error)
            {
                stopCameraScanner();
                setCameraStatus(`Unable to start camera scanner: ${error?.message || error}`);
            }
        };

        const showCameraOptions = async () => {
            if (!cameraScannerPanel)
            {
                return;
            }

            setCameraPanelVisibility(true);
            setCameraStatus("Loading available cameras...");

            try
            {
                await loadCameraDevices();
                if (!selectedCameraId)
                {
                    setCameraStatus("No camera was found on this device.");
                    return;
                }

                setCameraStatus("Choose a camera, then click Start Camera Scan.");
            }
            catch (error)
            {
                setCameraStatus(`Unable to load cameras: ${error?.message || error}`);
            }
        };

        if (cameraSourceSelect)
        {
            cameraSourceSelect.addEventListener("change", () => {
                selectedCameraId = cameraSourceSelect.value || null;
                saveCameraPreferences(localStorage.getItem(cameraPanelPreferenceKey) === "true");
                updateStartButtonState();
            });
        }

        if (showCameraOptionsButton)
        {
            showCameraOptionsButton.addEventListener("click", showCameraOptions);
        }

        if (startCameraScanButton)
        {
            startCameraScanButton.addEventListener("click", startCameraScanner);
        }

        if (stopCameraScanButton)
        {
            stopCameraScanButton.addEventListener("click", () => stopCameraScanner(true, true));
        }

        if (shouldShowSuccessPopup && scanSuccessToast && typeof bootstrap !== "undefined")
        {
            new bootstrap.Toast(scanSuccessToast, { delay: 1800 }).show();
        }

        if (shouldRestoreCameraPanel)
        {
            window.setTimeout(() => {
                showCameraOptions();
            }, 300);
        }

        window.addEventListener("beforeunload", () => stopCameraScanner());
    </script>
}
