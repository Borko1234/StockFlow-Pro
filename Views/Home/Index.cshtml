@model StockFlowPro.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Табло";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">Добре дошли, @Model.UserName!</h1>
        <span class="text-muted">@DateTime.Now.ToString("D")</span>
    </div>

    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-3">
                    <h5 class="card-title mb-0">Бързи действия</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-2">
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-controller="Admin" asp-action="Index" class="btn btn-primary">Admin Dashboard</a>
                            <a asp-controller="AdminOrders" asp-action="Index" class="btn btn-outline-primary">Manage Orders</a>
                            <a asp-controller="AdminProducts" asp-action="Index" class="btn btn-outline-success">Manage Products</a>
                            <a asp-controller="AdminEmployees" asp-action="Index" class="btn btn-outline-secondary">Manage Employees</a>
                            <a asp-controller="AdminFacilities" asp-action="Index" class="btn btn-outline-warning">Manage Facilities</a>
                        }
                        else if (User.IsInRole("OfficeWorker"))
                        {
                            <a asp-controller="Order" asp-action="Create" class="btn btn-primary">Create Order</a>
                            <a asp-controller="AdminOrders" asp-action="Index" class="btn btn-outline-primary">View Orders</a>
                        }
                        else if (User.IsInRole("Scanner"))
                        {
                            <a asp-controller="Scanner" asp-action="Index" class="btn btn-primary">Scanner Station</a>
                        }
                        else if (User.IsInRole("Packer"))
                        {
                            <a asp-controller="Packer" asp-action="Index" class="btn btn-primary">Packer Dashboard</a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- KPI Cards -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0 bg-primary bg-opacity-10 p-3 rounded">
                            <i class="bi bi-box-seam text-primary fs-3"></i>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="text-muted mb-0">Общо продукти</h6>
                            <h3 class="mb-0">@Model.TotalProducts</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm h-100 @(Model.LowStockCount > 0 ? "border-start border-danger border-4" : "")">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0 @(Model.LowStockCount > 0 ? "bg-danger" : "bg-warning") bg-opacity-10 p-3 rounded">
                            <i class="bi bi-exclamation-triangle @(Model.LowStockCount > 0 ? "text-danger" : "text-warning") fs-3"></i>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="text-muted mb-0">Нисък запас</h6>
                            <h3 class="mb-0 @(Model.LowStockCount > 0 ? "text-danger" : "")">@Model.LowStockCount</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0 bg-info bg-opacity-10 p-3 rounded">
                            <i class="bi bi-building text-info fs-3"></i>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="text-muted mb-0">Активни обекти</h6>
                            <h3 class="mb-0">@Model.FacilityCount</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0 bg-success bg-opacity-10 p-3 rounded">
                            <i class="bi bi-cart-check text-success fs-3"></i>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="text-muted mb-0">Активни поръчки</h6>
                            <h3 class="mb-0">@Model.ActiveOrdersCount</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Weekly Chart -->
        <div class="col-lg-8 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-3">
                    <h5 class="card-title">Движение на поръчки (Последни 7 дни)</h5>
                </div>
                <div class="card-body">
                    <canvas id="movementChart" style="min-height: 300px;"></canvas>
                </div>
            </div>
        </div>

        <!-- Recent Orders -->
        <div class="col-lg-4 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-3">
                    <h5 class="card-title">Последни поръчки</h5>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        @foreach (var order in Model.RecentOrders)
                        {
                            <div class="list-group-item border-0 border-bottom">
                                <div class="d-flex w-100 justify-content-between">
                                    <h6 class="mb-1">#@order.Id - @order.Facility?.Name</h6>
                                    <small class="text-muted">@order.CreatedAt.ToString("HH:mm")</small>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="badge @(order.OrderStatus == StockFlowPro.Models.Enums.OrderStatus.Delivered ? "bg-success" : "bg-info")">@order.OrderStatus</span>
                                    <span class="fw-bold">@order.TotalAmount.ToString("C")</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('movementChart').getContext('2d');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.WeeklyMovements.Select(m => m.Day))),
                datasets: [{
                    label: 'Брой поръчки',
                    data: @Html.Raw(Json.Serialize(Model.WeeklyMovements.Select(m => m.OrdersCount))),
                    backgroundColor: 'rgba(13, 110, 253, 0.7)',
                    borderColor: 'rgb(13, 110, 253)',
                    borderWidth: 1,
                    borderRadius: 5
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            stepSize: 1
                        }
                    }
                },
                plugins: {
                    legend: {
                        display: false
                    }
                }
            }
        });
    </script>
}
