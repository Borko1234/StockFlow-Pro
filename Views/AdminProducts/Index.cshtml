@model StockFlowPro.ViewModels.Admin.ProductListViewModel

@{
    ViewData["Title"] = "Управление на продукти";
    Layout = "_Layout";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h3 mb-0">Списък с продукти</h2>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#barcodeScannerModal">
                <i class="bi bi-qr-code-scan"></i> Сканирай
            </button>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Нов продукт
            </a>
        </div>
    </div>

    <!-- Filter Tabs -->
    <ul class="nav nav-tabs mb-4">
        <li class="nav-item">
            <a class="nav-link @(Model.Filter == "all" ? "active" : "")" 
               asp-action="Index" asp-route-filter="all" asp-route-search="@Model.Search">
                Всички <span class="badge bg-secondary ms-1">@Model.TotalCount</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(Model.Filter == "low" ? "active" : "")" 
               asp-action="Index" asp-route-filter="low" asp-route-search="@Model.Search">
                Нисък запас <span class="badge bg-danger ms-1">@Model.LowStockCount</span>
            </a>
        </li>
    </ul>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <!-- Search and Actions -->
            <form method="get" class="row g-3 mb-4">
                <input type="hidden" name="filter" value="@Model.Filter" />
                <input type="hidden" name="sortBy" value="@Model.SortBy" />
                <input type="hidden" name="sortDir" value="@Model.SortDir" />
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="text" name="search" class="form-control border-start-0" 
                               placeholder="Търси по име или марка..." value="@Model.Search">
                        <button class="btn btn-primary" type="submit">Търси</button>
                    </div>
                </div>
            </form>

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>
                                <a class="text-dark text-decoration-none" asp-action="Index" 
                                   asp-route-sortBy="name" asp-route-sortDir="@(Model.SortBy == "name" && Model.SortDir == "asc" ? "desc" : "asc")"
                                   asp-route-search="@Model.Search" asp-route-filter="@Model.Filter">
                                    Продукт @(Model.SortBy == "name" ? (Model.SortDir == "asc" ? "↑" : "↓") : "")
                                </a>
                            </th>
                            <th>Марка</th>
                            <th>
                                <a class="text-dark text-decoration-none" asp-action="Index" 
                                   asp-route-sortBy="stock" asp-route-sortDir="@(Model.SortBy == "stock" && Model.SortDir == "asc" ? "desc" : "asc")"
                                   asp-route-search="@Model.Search" asp-route-filter="@Model.Filter">
                                    Наличност @(Model.SortBy == "stock" ? (Model.SortDir == "asc" ? "↑" : "↓") : "")
                                </a>
                            </th>
                            <th>
                                <a class="text-dark text-decoration-none" asp-action="Index" 
                                   asp-route-sortBy="price" asp-route-sortDir="@(Model.SortBy == "price" && Model.SortDir == "asc" ? "desc" : "asc")"
                                   asp-route-search="@Model.Search" asp-route-filter="@Model.Filter">
                                    Цена @(Model.SortBy == "price" ? (Model.SortDir == "asc" ? "↑" : "↓") : "")
                                </a>
                            </th>
                            <th class="text-end">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Products)
                        {
                            <tr>
                                <td>
                                    <div class="fw-bold">@item.Name</div>
                                    @if (!string.IsNullOrEmpty(item.Barcode))
                                    {
                                        <small class="text-muted"><i class="bi bi-barcode"></i> @item.Barcode</small>
                                    }
                                </td>
                                <td>@item.Brand</td>
                                <td>
                                    @if (item.QuantityInStock == 0)
                                    {
                                        <span class="badge bg-danger">Изчерпан</span>
                                    }
                                    else if (item.QuantityInStock <= item.MinimumStockLevel)
                                    {
                                        <span class="badge bg-warning text-dark">@item.QuantityInStock бр. <i class="bi bi-exclamation-triangle"></i></span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">@item.QuantityInStock бр.</span>
                                    }
                                </td>
                                <td>@item.Price.ToString("C")</td>
                                <td class="text-end">
                                    <div class="btn-group">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" title="Редактирай">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Изтрий">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("_BarcodeScannerModal")
